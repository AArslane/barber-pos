# Copier vers .env.local et remplir depuis le dashboard Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# Clé secrète (Settings → API → clé "secret", sb_secret_xxxx) : server-only,
# jamais NEXT_PUBLIC_. Utilisée uniquement par l'onboarding pour créer le
# compte tablette (admin.auth.admin.createUser). Ne jamais commit la vraie valeur.
SUPABASE_SECRET_KEY=sb_secret_xxxx

# Stripe (abonnements SaaS) — optionnel : si absent, le gating abonnement est
# désactivé et le dashboard reste accessible sans facturation.
# Clé secrète (Developers → API keys), server-only, jamais NEXT_PUBLIC_.
STRIPE_SECRET_KEY=sk_test_xxxx
# Signing secret du endpoint webhook (Developers → Webhooks), server-only.
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Clé publique Stripe, exposée au client (non utilisée pour l'instant : le
# Checkout est entièrement redirigé côté serveur, mais conservée pour une
# éventuelle intégration Stripe.js côté client).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# ID du prix (Product → Pricing) de l'abonnement mensuel unique.
STRIPE_PRICE_ID=price_xxxx

# URL publique du site (canonical, OG, sitemap). En prod : le domaine final.
NEXT_PUBLIC_SITE_URL=https://barber-pos.vercel.app

# PostHog (analytics, cloud EU) — optionnel : si absent, aucun tracking.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx

# Clé API Resend (https://resend.com/api-keys) : emails de confirmation des
# réservations en ligne. Optionnelle — sans elle, la résa marche mais n'envoie
# pas d'email au client. À poser aussi dans les env vars Vercel (prod).
RESEND_API_KEY=
