# Copier vers .env.local et remplir depuis le dashboard Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# Clé secrète (Settings → API → clé "secret", sb_secret_xxxx) : server-only,
# jamais NEXT_PUBLIC_. Utilisée uniquement par l'onboarding pour créer le
# compte tablette (admin.auth.admin.createUser). Ne jamais commit la vraie valeur.
SUPABASE_SECRET_KEY=sb_secret_xxxx
